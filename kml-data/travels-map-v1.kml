			</LookAt>
			<styleUrl>#__managed_style_126AF034E73F6294FB47</styleUrl>
			<gx:Carousel>
				<gx:Image kml:id="hosted_image_">
					<gx:imageUrl>https://earth.usercontent.google.com/hostedimage/e/*/4AE5a_Gz63r2BVI-qsYR0lJJA07QcCMgOFbzMw5gItxPci7MgPhbDWeoZJqupDCsGmDeI68JK_5y795FQ4N-mC30-gdHmjBBQB09SCC4jdUm_MhhDNmMHRXtwIxf2aKHMfPTtcsqf5dV0IFVnhrieErcEzBDeQmsNYoNWh0W5Io83rcOSgqt55QdW6zFLI3BEmIevpZKdzNoy4x3exehhA8jdI-6gzObUIMWpLq3TVLH9Kc4uvFSjObKB3HEmS5PavHQBH1xgJ-6efAtLDyk?authuser=0&amp;fife=s{size}</gx:imageUrl>
