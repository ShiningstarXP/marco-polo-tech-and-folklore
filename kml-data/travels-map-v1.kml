				<coordinates>71.097317,37.6907163,0</coordinates>
			</Point>
		</Placemark>
		<Placemark id="0835AD15FA3F3A644062">
			<name>Kashmir</name>
			<description><![CDATA[<div><span style="overflow: visible; position: relative; width: 0px; height: 0px; display: block;"></span><br></div><div>Not directly visited on the journey eastward but detailed with particular attention to Buddhist monks (Polo and Latham, <i>The Travels of Marco Polo</i>, 65, 78).<br></div>]]></description>
			<LookAt>
				<longitude>74.85584090988922</longitude>
				<latitude>33.97143075986544</latitude>
				<altitude>1876.817979494827</altitude>
				<heading>9.187660703080004</heading>
				<tilt>0</tilt>
