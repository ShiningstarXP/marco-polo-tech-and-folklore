	<Folder id="00DF91A97E3F4403EE30">
		<name>(1271-1274) Journey to Xanadu/ Shangdu</name>
		<open>1</open>
		<description><![CDATA[<div><span style="overflow: visible; position: relative; width: 0px; height: 0px; display: block;"></span>This route marks the Journey of Marco Polo eastward from Venice to Xanadu/Shangdu, the summer palace of Kublai Khan. (Chapters 1-3)<br></div>]]></description>
		<styleUrl>#__managed_style_1D7FDEF4043F6294FB3F</styleUrl>
		<Placemark id="1B5994C8E03F43B2AE8E">
			<name>Path to Cambulac</name>
			<snippet></snippet>
			<LookAt>
				<longitude>115.6953965580512</longitude>
				<latitude>39.62744180124638</latitude>
				<altitude>662.6982115075572</altitude>
				<heading>0</heading>
				<tilt>0</tilt>
				<gx:fovy>35</gx:fovy>
				<range>712731.6656023264</range>
